# TikTok API Credentials
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_REFRESH_TOKEN=your_tiktok_refresh_token

# Instagram / Meta API Credentials
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# OpenAI API (for content generation)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# Anthropic API (alternative to OpenAI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Database (optional, for analytics)
DATABASE_URL=postgresql://user:password@localhost/socialmedia_db

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# Email (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password
